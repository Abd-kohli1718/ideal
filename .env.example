PORT=3001
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
FRONTEND_URL=

# Optional: Google AI Studio API key (free tier). If unset, triage uses built-in rules only.
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional override, e.g. gemini-2.0-flash or gemini-1.5-flash
GEMINI_MODEL=gemini-2.0-flash

# Optional: Mastodon-compatible base URL for POST /api/simulate/social (no API key; public timeline)
# MASTODON_INSTANCE=https://mastodon.social

# Optional: Reddit subreddit for simulate (no API key; public .json). Default: news
# REDDIT_SUBREDDIT=news
# Optional: descriptive User-Agent (Reddit API etiquette)
# REDDIT_USER_AGENT=YourApp/1.0 (contact url or description)
